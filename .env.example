# ─────────────────────────────────────────────────────────────
# kickoff-monad — environment
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# ── Monad network ──
# Testnet (default for the demo): chainId 10143, free test MON.
# Mainnet would be MONAD_RPC_URL=https://rpc.monad.xyz / MONAD_CHAIN_ID=143 (REAL MON).
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143

# ── Wallets ──
# Deployer / agent signer private key (the AI agent submits executeWinner txs)
PRIVATE_KEY=

# Optional: separate key for the agent if you don't want to reuse the deployer
AGENT_PRIVATE_KEY=

# ── Contract (filled in after deploy) ──
CONTRACT_ADDRESS=

# ── Claude (agent evaluation engine) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL serving the frontend (ngrok or deployed). Used for the Mini App button.
WEBAPP_URL=

# ── Backend ──
PORT=3001
WS_PORT=3002
MONAD_EXPLORER=https://testnet.monadexplorer.com

# Relayer: submits crowd offers on-chain (audience has no wallet/MON).
# Defaults to PRIVATE_KEY if unset. Use a SEPARATE key from the agent to avoid
# nonce collisions during the live demo. Fund it with enough MON for all bids.
RELAYER_PRIVATE_KEY=
# Safety cap per relayed offer (MON).
MAX_OFFER_MON=0.05

# ── Frontend (Vite — must be prefixed VITE_) ──
VITE_BACKEND_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3002
VITE_CONTRACT_ADDRESS=
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
VITE_MONAD_CHAIN_ID=10143
VITE_MONAD_EXPLORER=https://testnet.monadexplorer.com
# QR target for the Arena feed — your public Mini App / bot URL (ngrok).
VITE_BOT_URL=
